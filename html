<!doctype html>
<html lang="zh-TW" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>血腥風計時器</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Nosifer&amp;family=Creepster&amp;family=Noto+Sans+TC:wght@400;700;900&amp;display=swap" rel="stylesheet">
  <style>
    @keyframes drip {
      0% { transform: translateY(-100%); opacity: 0; }
      10% { opacity: 1; }
      90% { opacity: 1; }
      100% { transform: translateY(100vh); opacity: 0; }
    }
    
    @keyframes blood-flood {
      0% { height: 0; opacity: 0.9; }
      100% { height: 100%; opacity: 0.9; }
    }
    
    @keyframes pulse-glow {
      0%, 100% { text-shadow: 0 0 20px #8b0000, 0 0 40px #8b0000, 0 0 60px #ff0000; }
      50% { text-shadow: 0 0 40px #8b0000, 0 0 80px #8b0000, 0 0 120px #ff0000; }
    }
    
    @keyframes flicker {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.8; }
      75% { opacity: 0.9; }
    }
    
    @keyframes blood-pulse {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }
    
    .blood-drip {
      animation: drip 4s linear infinite;
    }
    
    .blood-flood-active {
      animation: blood-flood 3s ease-in forwards !important;
    }
    
    .title-glow {
      animation: pulse-glow 2s ease-in-out infinite;
    }
    
    .flicker {
      animation: flicker 0.5s ease-in-out infinite;
    }
    
    .blood-bg {
      background: linear-gradient(135deg, #1a0000 0%, #2d0a0a 25%, #0d0000 50%, #1a0505 75%, #0a0000 100%);
      background-size: 400% 400%;
      animation: blood-pulse 8s ease infinite;
    }
    
    .countdown-box {
      background: linear-gradient(180deg, rgba(139, 0, 0, 0.3) 0%, rgba(50, 0, 0, 0.6) 100%);
      border: 2px solid #8b0000;
      box-shadow: 0 0 20px rgba(139, 0, 0, 0.5), inset 0 0 30px rgba(0, 0, 0, 0.8);
    }
    
    .number-display {
      font-family: 'Nosifer', 'Noto Sans TC', cursive;
      color: #ff3333;
      text-shadow: 0 0 10px #ff0000, 0 0 20px #8b0000, 0 0 30px #8b0000;
    }
    
    .blood-text {
      background: linear-gradient(180deg, #ff4444 0%, #8b0000 50%, #4a0000 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 2px 4px rgba(139, 0, 0, 0.8));
    }
    
    .splatter {
      position: absolute;
      border-radius: 50%;
      background: radial-gradient(circle, #8b0000 0%, #4a0000 70%, transparent 100%);
      opacity: 0.6;
    }
  </style>
  <style>body { box-sizing: border-box; }</style>
  <script src="/_sdk/data_sdk.js" type="text/javascript"></script>
 </head>
 <body class="h-full overflow-auto">
  <div id="app-wrapper" class="w-full h-full blood-bg relative overflow-hidden">
   <!-- Blood flood overlay -->
   <div id="blood-flood" class="absolute inset-0 pointer-events-none" style="background: linear-gradient(to bottom, rgba(139, 0, 0, 0.9) 0%, rgba(80, 0, 0, 0.9) 50%, rgba(50, 0, 0, 0.95) 100%); height: 0; bottom: 0; z-index: 100;"></div><!-- Blood drips -->
   <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="blood-drip absolute left-[10%] w-1 h-32 bg-gradient-to-b from-transparent via-red-900 to-red-950 rounded-full" style="animation-delay: 0s;"></div>
    <div class="blood-drip absolute left-[25%] w-2 h-40 bg-gradient-to-b from-transparent via-red-800 to-red-950 rounded-full" style="animation-delay: 1s;"></div>
    <div class="blood-drip absolute left-[45%] w-1 h-24 bg-gradient-to-b from-transparent via-red-900 to-red-950 rounded-full" style="animation-delay: 2s;"></div>
    <div class="blood-drip absolute left-[65%] w-2 h-36 bg-gradient-to-b from-transparent via-red-800 to-red-950 rounded-full" style="animation-delay: 0.5s;"></div>
    <div class="blood-drip absolute left-[80%] w-1 h-28 bg-gradient-to-b from-transparent via-red-900 to-red-950 rounded-full" style="animation-delay: 1.5s;"></div>
    <div class="blood-drip absolute left-[90%] w-2 h-32 bg-gradient-to-b from-transparent via-red-800 to-red-950 rounded-full" style="animation-delay: 2.5s;"></div>
   </div><!-- Splatters -->
   <div class="splatter w-24 h-24 top-[5%] left-[5%]"></div>
   <div class="splatter w-16 h-16 top-[15%] right-[10%]"></div>
   <div class="splatter w-20 h-20 bottom-[10%] left-[15%]"></div>
   <div class="splatter w-12 h-12 bottom-[20%] right-[20%]"></div><!-- Main content -->
   <div class="relative z-10 flex flex-col items-center justify-center min-h-full px-4 py-8">
    <!-- Title -->
    <h1 id="main-title" class="text-4xl md:text-6xl lg:text-7xl font-black text-center mb-2 title-glow blood-text" style="font-family: 'Creepster', 'Noto Sans TC', cursive;">一中科學班考試倒數</h1><!-- Subtitle -->
    <p id="target-date-label" class="text-red-500 text-lg md:text-xl mb-8 tracking-widest flicker" style="font-family: 'Noto Sans TC', sans-serif;">倒數至 2026年3月14日</p><!-- Countdown boxes -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 w-full max-w-4xl mb-8">
     <!-- Days -->
     <div class="countdown-box rounded-lg p-4 md:p-6 text-center transform hover:scale-105 transition-transform">
      <div id="days" class="number-display text-4xl md:text-6xl lg:text-7xl font-bold">
       000
      </div>
      <div class="text-red-400 text-sm md:text-base mt-2 uppercase tracking-wider" style="font-family: 'Noto Sans TC', sans-serif;">
       天
      </div>
     </div><!-- Hours -->
     <div class="countdown-box rounded-lg p-4 md:p-6 text-center transform hover:scale-105 transition-transform">
      <div id="hours" class="number-display text-4xl md:text-6xl lg:text-7xl font-bold">
       00
      </div>
      <div class="text-red-400 text-sm md:text-base mt-2 uppercase tracking-wider" style="font-family: 'Noto Sans TC', sans-serif;">
       時
      </div>
     </div><!-- Minutes -->
     <div class="countdown-box rounded-lg p-4 md:p-6 text-center transform hover:scale-105 transition-transform">
      <div id="minutes" class="number-display text-4xl md:text-6xl lg:text-7xl font-bold">
       00
      </div>
      <div class="text-red-400 text-sm md:text-base mt-2 uppercase tracking-wider" style="font-family: 'Noto Sans TC', sans-serif;">
       分
      </div>
     </div><!-- Seconds -->
     <div class="countdown-box rounded-lg p-4 md:p-6 text-center transform hover:scale-105 transition-transform">
      <div id="seconds" class="number-display text-4xl md:text-6xl lg:text-7xl font-bold flicker">
       00
      </div>
      <div class="text-red-400 text-sm md:text-base mt-2 uppercase tracking-wider" style="font-family: 'Noto Sans TC', sans-serif;">
       秒
      </div>
     </div>
    </div><!-- Decorative skulls using emoji -->
    <div class="flex items-center gap-4 text-4xl md:text-5xl opacity-70">
     <span class="transform hover:scale-125 transition-transform cursor-default">💀</span> <span class="transform hover:scale-125 transition-transform cursor-default">🩸</span> <span class="transform hover:scale-125 transition-transform cursor-default">⚰️</span> <span class="transform hover:scale-125 transition-transform cursor-default">🩸</span> <span class="transform hover:scale-125 transition-transform cursor-default">💀</span>
    </div>
   </div>
  </div>
  <script>
    const defaultConfig = {
      main_title: '一中科學班考試倒數',
      target_date_label: '倒數至 2026年3月14日',
      background_color: '#1a0000',
      text_color: '#ff3333',
      accent_color: '#8b0000',
      secondary_color: '#4a0000',
      highlight_color: '#ff4444',
      font_family: 'Noto Sans TC',
      font_size: 16
    };

    const targetDate = new Date('2026-03-14T00:00:00').getTime();
    let isTimeUp = false;

    function updateCountdown() {
      const now = new Date().getTime();
      const distance = targetDate - now;

      if (distance < 0 && !isTimeUp) {
        isTimeUp = true;
        // 時間一到，開始血液滿屏
        const bloodFlood = document.getElementById('blood-flood');
        bloodFlood.classList.add('blood-flood-active');
      }

      if (distance < 0) {
        document.getElementById('days').textContent = '000';
        document.getElementById('hours').textContent = '00';
        document.getElementById('minutes').textContent = '00';
        document.getElementById('seconds').textContent = '00';
        return;
      }

      const days = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((distance % (1000 * 60)) / 1000);

      // 每過一秒流一滴血
      const bloodDrips = document.querySelectorAll('.blood-drip');
      bloodDrips.forEach((drip, index) => {
        // 重新觸發動畫
        drip.style.animation = 'none';
        setTimeout(() => {
          drip.style.animation = `drip 4s linear infinite`;
          drip.style.animationDelay = `${(seconds + index * 0.5) % 4}s`;
        }, 10);
      });

      document.getElementById('days').textContent = String(days).padStart(3, '0');
      document.getElementById('hours').textContent = String(hours).padStart(2, '0');
      document.getElementById('minutes').textContent = String(minutes).padStart(2, '0');
      document.getElementById('seconds').textContent = String(seconds).padStart(2, '0');
    }

    async function onConfigChange(config) {
      const titleEl = document.getElementById('main-title');
      const labelEl = document.getElementById('target-date-label');
      
      titleEl.textContent = config.main_title || defaultConfig.main_title;
      labelEl.textContent = config.target_date_label || defaultConfig.target_date_label;

      const customFont = config.font_family || defaultConfig.font_family;
      const baseFontStack = 'Noto Sans TC, sans-serif';
      titleEl.style.fontFamily = `Creepster, ${customFont}, ${baseFontStack}`;
      labelEl.style.fontFamily = `${customFont}, ${baseFontStack}`;

      const baseSize = config.font_size || defaultConfig.font_size;
      labelEl.style.fontSize = `${baseSize * 1.25}px`;
    }

    function mapToCapabilities(config) {
      return {
        recolorables: [
          {
            get: () => config.background_color || defaultConfig.background_color,
            set: (value) => {
              config.background_color = value;
              window.elementSdk.setConfig({ background_color: value });
            }
          },
          {
            get: () => config.text_color || defaultConfig.text_color,
            set: (value) => {
              config.text_color = value;
              window.elementSdk.setConfig({ text_color: value });
            }
          },
          {
            get: () => config.accent_color || defaultConfig.accent_color,
            set: (value) => {
              config.accent_color = value;
              window.elementSdk.setConfig({ accent_color: value });
            }
          }
        ],
        borderables: [],
        fontEditable: {
          get: () => config.font_family || defaultConfig.font_family,
          set: (value) => {
            config.font_family = value;
            window.elementSdk.setConfig({ font_family: value });
          }
        },
        fontSizeable: {
          get: () => config.font_size || defaultConfig.font_size,
          set: (value) => {
            config.font_size = value;
            window.elementSdk.setConfig({ font_size: value });
          }
        }
      };
    }

    function mapToEditPanelValues(config) {
      return new Map([
        ['main_title', config.main_title || defaultConfig.main_title],
        ['target_date_label', config.target_date_label || defaultConfig.target_date_label]
      ]);
    }

    if (window.elementSdk) {
      window.elementSdk.init({
        defaultConfig,
        onConfigChange,
        mapToCapabilities,
        mapToEditPanelValues
      });
    }

    // Start countdown
    updateCountdown();
    setInterval(updateCountdown, 1000);
  </script>
